{
  "name": "@thenormvg/web-have-sounds",
  "version": "1.6.4",
  "description": "Procedurally generated, zero-dependency UI sounds using the native Web Audio API.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NormVg/web-have-sound.git"
  },
  "bugs": {
    "url": "https://github.com/NormVg/web-have-sound/issues"
  },
  "homepage": "https://github.com/NormVg/web-have-sound#readme",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "audio",
    "ui",
    "sounds",
    "synthesis",
    "web-audio-api"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}
